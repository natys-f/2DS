Algoritmo "calcular area de um retangulo"


Var
valor : inteiro
valor2 : inteiro
valor3 : real
dolar : real

Inicio

 escreval (" digite o valor da base:")
leia (valor)
escreval (" digite o valor da altura: ")
leia (valor2)
escreval ("")
escreval (valor*valor2)
escreval ("")
escreval ("digite o valor do dolar: ")
leia (valor3)
dolar <- 5.25
escreval (valor3*dolar)
escreval ("")
Fimalgoritmo